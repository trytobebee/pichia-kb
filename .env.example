# At minimum one of these is required (matching whichever provider you point
# `model` at in CLI flags / config). All providers are loaded lazily, so you
# only need the key for the model(s) you actually use.

# Google Gemini — used by FigureExtractor (vision) and CuratorAgent (function
# calling). Required if you want figure extraction or schema-curator chat.
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek — OpenAI-compatible. Use for `model=deepseek-v4-flash` etc. when
# on servers where Google APIs are unreachable (e.g. Aliyun mainland).
# DEEPSEEK_API_KEY=sk-...

# OpenAI direct (gpt-4o, gpt-4o-mini, o1-*, etc.). Optional.
# OPENAI_API_KEY=sk-...

# 阿里灵积 (DashScope) — for Qwen models, including Qwen-VL vision. Useful
# on Aliyun-mainland deployments where Gemini vision is unreachable.
# DASHSCOPE_API_KEY=sk-...

# 火山引擎 Ark — for Doubao models (text + vision). Alternative to DashScope.
# ARK_API_KEY=...

# Default model for all CLI commands and the web Q&A. Override per-command
# with --model. On servers without Google API access (e.g. Aliyun mainland)
# set this to a DeepSeek model id, e.g.:
# KB_DEFAULT_MODEL=deepseek-v4-flash
